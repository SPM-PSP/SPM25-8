A;AAHA,GAAA;AAKA,EAAA,OAAA,CAAA,KAAA,GAAA,IAAA;AAEA,QAAA,WAAA,GAAA,IAAA,WAAA,CACA,qBAAA,QAAA,CAAA,KAAA,CAAA,KAAA,YAAA,kBAAA,CAAA,OAAA,CAAA,EADA,CAAA;AAGA,EAAA,QAAA,CAAA,KAAA,CAAA,OAAA,GAAA,EAAA;;AAEA,EAAA,WAAA,CAAA,SAAA,GAAA,KAAA,IAAA;AACA,QAAA,QAAA,GAAA,KAAA,CAAA,IAAA;AACA,IAAA,OAAA,CAAA,GAAA,CAAA,QAAA;;AACA,QAAA,QAAA,IAAA,KAAA,EAAA;AACA,MAAA,KAAA;AACA;AACA;;AACA,IAAA,QAAA,GAAA,IAAA,CAAA,KAAA,CAAA,QAAA,EAAA,OAAA;AACA,IAAA,WAAA,CAAA,KAAA,CAAA,WAAA,CAAA,KAAA,CAAA,MAAA,GAAA,CAAA,EAAA,OAAA,CAAA,IAAA,CAAA,QAAA,EARA,CASA;;AACA,IAAA,QAAA,CAAA,MAAA;AACA,YAAA,OAAA,GAAA,QAAA,CAAA,cAAA,CAAA,eAAA,CAAA;AACA,MAAA,OAAA,CAAA,SAAA,GAAA,OAAA,CAAA,YAAA;AACA,KAHA,CAAA;AAIA,GAdA;;AAgBA,EAAA,WAAA,CAAA,OAAA,GAAA,KAAA,IAAA;AACA,IAAA,KAAA;AACA,GAFA;;AAIA,QAAA,KAAA,GAAA,MAAA;AACA,IAAA,WAAA,CAAA,KAAA;AACA,IAAA,WAAA,CAAA,KAAA,CAAA,WAAA,CAAA,KAAA,CAAA,MAAA,GAAA,CAAA,EAAA,OAAA,GAAA,KAAA;AACA,IAAA,OAAA,CAAA,KAAA,GAAA,KAAA;AACA,GAJA;AAKA,CApDA","sourcesContent":["<template>\r\n  <div class=\"ai-container\">\r\n    <div class=\"chat-title\">AI智能助手</div>\r\n    <div class=\"message-panel\" id=\"message-panel\">\r\n      <div class=\"message-list\">\r\n        <div\r\n          :class=\"['message-item', item.type == 1 ? 'ai-item' : '']\"\r\n          v-for=\"(item, index) in messageList\"\r\n          :key=\"index\"\r\n          :id=\"'item' + index\"\r\n        >\r\n          <template v-if=\"item.type == 0\">\r\n            <div class=\"message-content\">\r\n              <div class=\"content-inner\">{{ item.content }}</div>\r\n            </div>\r\n            <div class=\"user-icon\">我</div>\r\n          </template>\r\n          <template v-else>\r\n            <div class=\"user-icon\">AI</div>\r\n            <div class=\"message-content ai-item\">\r\n              <MdPreview\r\n                previewTheme=\"vuepress\"\r\n                :codeFoldable=\"false\"\r\n                editorId=\"preview\"\r\n                :modelValue=\"item.content.join('')\"\r\n              />\r\n              <div class=\"loading\" v-if=\"item.loading\">\r\n                <i class=\"el-icon-loading\"></i>\r\n              </div>\r\n            </div>\r\n          </template>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"send-panel\">\r\n      <el-form :model=\"formData\" ref=\"formDataRef\" @submit.prevent>\r\n        <!-- 下拉框 -->\r\n        <el-form-item label=\"模型\">\r\n          <el-select placeholder=\"选择模型\" v-model=\"formData.model\">\r\n            <el-option value=\"4.0Ultra\" label=\"科大讯飞\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <!--input输入-->\r\n        <el-form-item label=\"\" prop=\"content\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            :rows=\"3\"\r\n            placeholder=\"请输入你想问的问题\"\r\n            v-model=\"formData.content\"\r\n            @keyup=\"keySend\"\r\n          ></el-input>\r\n        </el-form-item>\r\n        <!--input输入-->\r\n        <el-form-item label=\"\" prop=\"\" class=\"send-btn\">\r\n          <el-button type=\"primary\" @click=\"sendMessage\" :disabled=\"loading\"\r\n            >发送(Ctrl+Enter)</el-button\r\n          >\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script setup>\r\nimport { ref, nextTick, getCurrentInstance } from \"vue\";\r\nimport { MdPreview } from \"md-editor-v3\";\r\nimport \"md-editor-v3/lib/style.css\";\r\n\r\nconst { proxy } = getCurrentInstance();\r\n\r\nconst formData = ref({\r\n  model: \"4.0Ultra\",\r\n  content: \"\"\r\n});\r\nconst messageList = ref([]);\r\nconst loading = ref(false);\r\n\r\nconst keySend = (event) => {\r\n  if (!(event.ctrlKey && event.key === \"Enter\")) {\r\n    return;\r\n  }\r\n  sendMessage();\r\n};\r\n\r\nconst sendMessage = () => {\r\n  const message = formData.value.content;\r\n  if (!message) {\r\n    proxy.$message({\r\n      type: \"warning\",\r\n      message: \"请输入内容\",\r\n      duration: 2000\r\n    });\r\n    return;\r\n  }\r\n  messageList.value.push({\r\n    type: 0,\r\n    content: message\r\n  });\r\n\r\n  messageList.value.push({\r\n    type: 1,\r\n    content: [],\r\n    loading: true\r\n  });\r\n  loading.value = true;\r\n\r\n  const eventSource = new EventSource(\r\n    `/api/stream?model=${formData.value.model}&message=${encodeURIComponent(message)}`\r\n  );\r\n  formData.value.content = \"\";\r\n  \r\n  eventSource.onmessage = (event) => {\r\n    let response = event.data;\r\n    console.log(response);\r\n    if (response == \"end\") {\r\n      close();\r\n      return;\r\n    }\r\n    response = JSON.parse(response).content;\r\n    messageList.value[messageList.value.length - 1].content.push(response);\r\n    // 滚动到底部\r\n    nextTick(() => {\r\n      const content = document.getElementById(\"message-panel\");\r\n      content.scrollTop = content.scrollHeight;\r\n    });\r\n  };\r\n\r\n  eventSource.onerror = (error) => {\r\n    close();\r\n  };\r\n\r\n  const close = () => {\r\n    eventSource.close();\r\n    messageList.value[messageList.value.length - 1].loading = false;\r\n    loading.value = false;\r\n  };\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.ai-container {\r\n  background: #f8f8f8;\r\n  height: calc(100vh - 50px);\r\n  padding: 10px;\r\n}\r\n\r\n.chat-title {\r\n  text-align: center;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.message-panel {\r\n  position: relative;\r\n  height: calc(100vh - 280px);\r\n  overflow: auto;\r\n  padding-bottom: 10px;\r\n  \r\n  .message-list {\r\n    margin: 0px auto;\r\n    max-width: 800px;\r\n    \r\n    .message-item {\r\n      margin: 10px 0px;\r\n      display: flex;\r\n      \r\n      .user-icon {\r\n        width: 40px;\r\n        height: 40px;\r\n        line-height: 40px;\r\n        border-radius: 20px;\r\n        background: #535353;\r\n        color: #fff;\r\n        text-align: center;\r\n        margin-left: 10px;\r\n      }\r\n      \r\n      .message-content {\r\n        flex: 1;\r\n        margin-left: 10px;\r\n        align-items: center;\r\n        display: flex;\r\n        justify-content: flex-end;\r\n      }\r\n      \r\n      .content-inner {\r\n        background: #2d65f7;\r\n        border-radius: 5px;\r\n        padding: 10px;\r\n        color: #fff;\r\n        max-width: 80%;\r\n      }\r\n    }\r\n    \r\n    .ai-item {\r\n      line-height: 23px;\r\n      \r\n      .message-content {\r\n        display: block;\r\n        background: #fff;\r\n        border-radius: 5px;\r\n        padding: 10px;\r\n      }\r\n      \r\n      .user-icon {\r\n        background: #64018f;\r\n        margin-left: 0px;\r\n      }\r\n      \r\n      :deep(.md-editor-previewOnly) {\r\n        border-radius: 5px;\r\n        background: #fff;\r\n      }\r\n      \r\n      :deep(.md-editor-preview-wrapper) {\r\n        padding: 10px;\r\n      }\r\n      \r\n      .loading {\r\n        text-align: center;\r\n        margin-top: 10px;\r\n        \r\n        i {\r\n          font-size: 24px;\r\n          color: #409EFF;\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.send-panel {\r\n  position: relative;\r\n  margin: 5px auto 0px;\r\n  max-width: 800px;\r\n  background: #fff;\r\n  border-radius: 5px;\r\n  padding: 10px;\r\n  \r\n  .send-btn {\r\n    text-align: right;\r\n    margin-bottom: 0px;\r\n    padding: 5px;\r\n    \r\n    :deep(.el-form-item__content) {\r\n      justify-content: flex-end;\r\n    }\r\n  }\r\n  \r\n  :deep(.el-textarea__inner) {\r\n    border: 0 !important;\r\n    resize: none !important;\r\n    box-shadow: none;\r\n  }\r\n}\r\n</style> "],"sourceRoot":"src/views/user"}]}