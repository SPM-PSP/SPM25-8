{"remainingRequest":"E:\\HealthManage\\personal-heath-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!E:\\HealthManage\\personal-heath-view\\src\\views\\user\\AI.vue?vue&type=style&index=0&id=4288e47c&lang=scss&scoped=true&","dependencies":[{"path":"E:\\HealthManage\\personal-heath-view\\src\\views\\user\\AI.vue","mtime":1745067809722},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\css-loader\\dist\\cjs.js","mtime":499162500000},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":499162500000},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\postcss-loader\\src\\index.js","mtime":499162500000},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\sass-loader\\dist\\cjs.js","mtime":499162500000},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":499162500000},{"path":"E:\\HealthManage\\personal-heath-view\\node_modules\\vue-loader\\lib\\index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["AI.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsJA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"AI.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\r\n  <div class=\"ai-container\">\r\n    <div class=\"chat-title\">AI智能助手</div>\r\n    <div class=\"message-panel\" id=\"message-panel\">\r\n      <div class=\"message-list\">\r\n        <div\r\n          :class=\"['message-item', item.type == 1 ? 'ai-item' : '']\"\r\n          v-for=\"(item, index) in messageList\"\r\n          :key=\"index\"\r\n          :id=\"'item' + index\"\r\n        >\r\n          <template v-if=\"item.type == 0\">\r\n            <div class=\"message-content\">\r\n              <div class=\"content-inner\">{{ item.content }}</div>\r\n            </div>\r\n            <div class=\"user-icon\">我</div>\r\n          </template>\r\n          <template v-else>\r\n            <div class=\"user-icon\">AI</div>\r\n            <div class=\"message-content ai-item\">\r\n              <div class=\"ai-response\" v-html=\"formatResponse(item.content.join(''))\"></div>\r\n              <div class=\"loading\" v-if=\"item.loading\">\r\n                <i class=\"el-icon-loading\"></i>\r\n              </div>\r\n            </div>\r\n          </template>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <div class=\"send-panel\">\r\n      <el-form :model=\"formData\" ref=\"formDataRef\" @submit.native.prevent>\r\n        <!-- 下拉框 -->\r\n        <el-form-item label=\"模型\">\r\n          <el-select placeholder=\"选择模型\" v-model=\"formData.model\">\r\n            <el-option value=\"4.0Ultra\" label=\"科大讯飞\"></el-option>\r\n          </el-select>\r\n        </el-form-item>\r\n        <!--input输入-->\r\n        <el-form-item label=\"\" prop=\"content\">\r\n          <el-input\r\n            type=\"textarea\"\r\n            :rows=\"3\"\r\n            placeholder=\"请输入你想问的问题\"\r\n            v-model=\"formData.content\"\r\n            @keyup.native=\"keySend\"\r\n          ></el-input>\r\n        </el-form-item>\r\n        <!--input输入-->\r\n        <el-form-item label=\"\" prop=\"\" class=\"send-btn\">\r\n          <el-button type=\"primary\" @click=\"sendMessage\" :disabled=\"loading\"\r\n            >发送(Ctrl+Enter)</el-button\r\n          >\r\n        </el-form-item>\r\n      </el-form>\r\n    </div>\r\n  </div>\r\n</template>\r\n<script>\r\nexport default {\r\n  name: \"AIAssistant\",\r\n  data() {\r\n    return {\r\n      formData: {\r\n        model: \"4.0Ultra\",\r\n        content: \"\"\r\n      },\r\n      messageList: [],\r\n      loading: false\r\n    };\r\n  },\r\n  methods: {\r\n    keySend(event) {\r\n      if (!(event.ctrlKey && event.key === \"Enter\")) {\r\n        return;\r\n      }\r\n      this.sendMessage();\r\n    },\r\n    sendMessage() {\r\n      const message = this.formData.content;\r\n      if (!message) {\r\n        this.$message({\r\n          type: \"warning\",\r\n          message: \"请输入内容\",\r\n          duration: 2000\r\n        });\r\n        return;\r\n      }\r\n      this.messageList.push({\r\n        type: 0,\r\n        content: message\r\n      });\r\n\r\n      this.messageList.push({\r\n        type: 1,\r\n        content: [],\r\n        loading: true\r\n      });\r\n      this.loading = true;\r\n\r\n      const eventSource = new EventSource(\r\n        `http://localhost:21090/api/personal-heath/v1.0/stream?model=${\r\n          this.formData.model\r\n        }&content=${encodeURIComponent(message)}`\r\n      );\r\n      this.formData.content = \"\";\r\n      \r\n      eventSource.onmessage = (event) => {\r\n        let response = event.data;\r\n        console.log(response);\r\n        if (response == \"end\") {\r\n          this.closeEventSource(eventSource);\r\n          return;\r\n        }\r\n        response = JSON.parse(response).content;\r\n        this.messageList[this.messageList.length - 1].content.push(response);\r\n        // 滚动到底部\r\n        this.$nextTick(() => {\r\n          const content = document.getElementById(\"message-panel\");\r\n          content.scrollTop = content.scrollHeight;\r\n        });\r\n      };\r\n\r\n      eventSource.onerror = (error) => {\r\n        this.closeEventSource(eventSource);\r\n      };\r\n    },\r\n    closeEventSource(eventSource) {\r\n      eventSource.close();\r\n      this.messageList[this.messageList.length - 1].loading = false;\r\n      this.loading = false;\r\n    },\r\n    formatResponse(text) {\r\n      if (!text) return '';\r\n      \r\n      // Replace newlines with <br>\r\n      let formatted = text.replace(/\\n/g, '<br>');\r\n      \r\n      // Highlight code blocks\r\n      formatted = formatted.replace(/```([\\s\\S]*?)```/g, '<pre class=\"code-block\">$1</pre>');\r\n      \r\n      // Highlight inline code\r\n      formatted = formatted.replace(/`([^`]+)`/g, '<code>$1</code>');\r\n      \r\n      return formatted;\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.ai-container {\r\n  background: #f8f8f8;\r\n  height: calc(100vh - 50px);\r\n  padding: 10px;\r\n}\r\n\r\n.chat-title {\r\n  text-align: center;\r\n  font-size: 20px;\r\n  font-weight: bold;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n.message-panel {\r\n  position: relative;\r\n  height: calc(100vh - 280px);\r\n  overflow: auto;\r\n  padding-bottom: 10px;\r\n  \r\n  .message-list {\r\n    margin: 0px auto;\r\n    max-width: 800px;\r\n    \r\n    .message-item {\r\n      margin: 10px 0px;\r\n      display: flex;\r\n      \r\n      .user-icon {\r\n        width: 40px;\r\n        height: 40px;\r\n        line-height: 40px;\r\n        border-radius: 20px;\r\n        background: #535353;\r\n        color: #fff;\r\n        text-align: center;\r\n        margin-left: 10px;\r\n      }\r\n      \r\n      .message-content {\r\n        flex: 1;\r\n        margin-left: 10px;\r\n        align-items: center;\r\n        display: flex;\r\n        justify-content: flex-end;\r\n      }\r\n      \r\n      .content-inner {\r\n        background: #2d65f7;\r\n        border-radius: 5px;\r\n        padding: 10px;\r\n        color: #fff;\r\n        max-width: 80%;\r\n      }\r\n    }\r\n    \r\n    .ai-item {\r\n      line-height: 23px;\r\n      \r\n      .message-content {\r\n        display: block;\r\n        background: #fff;\r\n        border-radius: 5px;\r\n        padding: 10px;\r\n      }\r\n      \r\n      .user-icon {\r\n        background: #64018f;\r\n        margin-left: 0px;\r\n      }\r\n      \r\n      .ai-response {\r\n        white-space: pre-wrap;\r\n        word-break: break-word;\r\n      }\r\n      \r\n      .ai-response >>> .code-block, \r\n      .ai-response >>> pre {\r\n        background-color: #f5f5f5;\r\n        border-radius: 4px;\r\n        padding: 10px;\r\n        margin: 10px 0;\r\n        overflow-x: auto;\r\n        font-family: monospace;\r\n        border: 1px solid #ddd;\r\n      }\r\n      \r\n      .ai-response >>> code {\r\n        background-color: #f5f5f5;\r\n        padding: 2px 4px;\r\n        border-radius: 3px;\r\n        font-family: monospace;\r\n        color: #d63384;\r\n      }\r\n      \r\n      .loading {\r\n        text-align: center;\r\n        margin-top: 10px;\r\n        \r\n        i {\r\n          font-size: 24px;\r\n          color: #409EFF;\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n\r\n.send-panel {\r\n  position: relative;\r\n  margin: 5px auto 0px;\r\n  max-width: 800px;\r\n  background: #fff;\r\n  border-radius: 5px;\r\n  padding: 10px;\r\n  \r\n  .send-btn {\r\n    text-align: right;\r\n    margin-bottom: 0px;\r\n    padding: 5px;\r\n  }\r\n}\r\n</style> "]}]}